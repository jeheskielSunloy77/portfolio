#!/usr/bin/env sh

# $1 = previous HEAD, $2 = new HEAD, $3 = flag (1 for branch checkout)
IS_BRANCH_CHECKOUT="$3"

# Only proceed if we are switching to a branch (which happens during worktree add)
if [ "$IS_BRANCH_CHECKOUT" = "1" ]; then
	# The common-dir points to the main .git folder even from within a worktree.
	COMMON_DIR=$(git rev-parse --git-common-dir)
	MAIN_REPO_ROOT=$(cd "$COMMON_DIR/.." && pwd)
	CURRENT_DIR=$(git rev-parse --show-toplevel)

	# Skip the main checkout so we do not overwrite its .env or reinstall deps there.
	if [ "$CURRENT_DIR" = "$MAIN_REPO_ROOT" ]; then
		exit 0
	fi

	echo "Worktree detected: $(basename "$CURRENT_DIR")"

	if [ -f "$MAIN_REPO_ROOT/.env" ] && [ ! -f ".env" ]; then
		echo "Getting .env file..."
		cp "$MAIN_REPO_ROOT/.env" .env
	fi

	if [ -f "package.json" ] && [ ! -d "node_modules" ]; then
		echo "Installing dependencies..."
		bun install --frozen-lockfile
	fi

	echo "Worktree setup complete."
fi
