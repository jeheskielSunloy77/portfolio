---
import { BOT_NAME, NICK_NAME, SOURCE_CODE_URL } from '@/lib/constants'
import type { Dictionary } from '@/lib/types'
import { ArrowDown, ArrowDownRight, Bot } from 'lucide-react'
import { HeroRobot } from './hero-robot'
import { ResumeButton } from './hero-section.client'
import Socials from './socials.astro'

export interface Props {
	t: Dictionary
}

const { t }: Props = Astro.props
---

<section
	id='hero'
	data-reveal-group
	data-reveal-stagger='100'
	class='mx-auto max-w-3xl px-4 sm:px-8 grid grid-cols-1 sm:grid-cols-2 items-center sm:border-b'
>
	<div class='flex flex-col'>
		<h1
			class='font-serif text-5xl tracking-wide decoration-border/75 decoration-2 text-balance'
			data-reveal='fade-up'
		>
			{t['hi {NICK_NAME} here 👋'].replace('{NICK_NAME}', NICK_NAME)}
		</h1>

		<p
			class='mt-2 whitespace-nowrap text-sm font-medium sm:text-base'
			data-reveal='fade-up'
		>
			{t['software engineer hailing from Indonesia 🇮🇩']}
		</p>

		<p
			class='mt-4 max-w-sm text-balance text-sm sm:text-base'
			data-reveal='fade-up'
		>
			{
				t[
					'I turn bugs into features and coffee into code. AI wrote this tagline. I just hit enter.'
				]
			}
		</p>

		<div class='mt-6 flex items-center gap-1' data-reveal='fade-up'>
			<p
				class='text-balance text-sm font-semibold sm:text-base flex items-center gap-1'
			>
				{t['For Q&A, raise a ticket with']}
				<Bot className='size-5' />
				{BOT_NAME}
			</p>
			<ArrowDownRight
				className='hidden size-5 motion-safe:animate-[bounce_1.8s_ease-in-out_infinite] sm:block'
			/>
			<ArrowDown
				className='block size-5 motion-safe:animate-[bounce_1.8s_ease-in-out_infinite] sm:hidden'
			/>
		</div>

		<p class='mt-1 text-xs font-light text-muted-foreground' data-reveal='fade-up'>
this site is 100% opensource,
			<a
				href={SOURCE_CODE_URL}
				target='_blank'
				class='motion-link text-foreground hover:underline font-semibold'
				title='Source Code URL'
			>
			source code
			</a>
		</p>

		<section class='mt-6 flex flex-wrap items-center gap-6' data-reveal='fade-up'>
			<ResumeButton client:idle />
			<Socials />
		</section>
	</div>

	<div data-reveal='scale-in' class='sm:block hidden'>
		<HeroRobot client:visible />
	</div>
</section>
