---
import ProjectList from '@/components/project-list.astro'
import { dictionary } from '@/i18n/dictionary'
import { type Language } from '@/i18n/i18n'
import MainLayout from '@/layouts/main.astro'

export interface Props {
	lang: Language
}

const lang = Astro.props.lang
const t = dictionary[lang]
---

<MainLayout
	lang={lang}
	seo={{
		title: t['Projects'],
		description:
			t[
				'Explore my projects, showcasing my skills and creativity in web development.'
			],
	}}
>
	<article
		class='mx-auto mt-8 flex w-full max-w-3xl flex-col gap-8 px-4 pt-24 pb-40 sm:px-8'
		data-reveal-group
	>
		<h1
			class='font-serif text-5xl tracking-wide decoration-border/75 decoration-2'
			data-reveal='fade-up'
		>
			{t['my projects.']}
		</h1>
		<ProjectList t={t} />
	</article>
</MainLayout>
