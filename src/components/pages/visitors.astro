---
import { Sketch } from '@/components/sketch'
import { dictionary } from '@/i18n/dictionary'
import type { Language } from '@/i18n/i18n'
import MainLayout from '@/layouts/main.astro'
import { getSketches, SKETCHES_PAGE_SIZE } from '@/lib/sketches'

export interface Props {
	lang: Language
}

const lang = Astro.props.lang
const t = dictionary[lang]

const firstPage = await getSketches(0, SKETCHES_PAGE_SIZE)
const initialData = {
	pages: [firstPage],
	pageParams: [0],
}
---

<MainLayout
	lang={lang}
	seo={{
		title: t['Visitors Wall'],
		description:
			t[
				'Browse visitor doodles and leave your own mark on this interactive portfolio wall.'
			],
	}}
>
	<article class='mx-auto mt-8 flex w-full max-w-3xl flex-col gap-8 px-4 pt-24 pb-40 sm:px-8'>
		<h1
			class='font-serif text-5xl tracking-wide decoration-border/75 decoration-2'
		>
			{t['visitors marks']}
		</h1>
		<Sketch client:idle t={t} initialData={initialData} />
	</article>
</MainLayout>
