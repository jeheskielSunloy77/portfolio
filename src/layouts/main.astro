---
import '../styles/global.css'
import Footer from '@/components/footer.astro'
import { ChatBot } from '@/components/chat-bot'
import Seo from '@/components/seo.astro'
import type { ComponentProps } from 'astro/types'
import ArticleSchema from '@/components/article-schema.astro'
import { type Language } from '@/i18n/i18n'
import { Navbar } from '@/components/navbar'
import { dictionary } from '@/i18n/dictionary'
import { BackgroundParticles } from '@/components/background-particles'

export interface Props {
	seo: Omit<ComponentProps<typeof Seo>, 'lang'>
	articleSchema?: ComponentProps<typeof ArticleSchema>
	lang: Language
	languageSwitchUrls?: Partial<Record<Language, string>>
	chatBot?: boolean
	dockNavbar?: boolean
}

const {
	seo,
	articleSchema,
	lang,
	languageSwitchUrls,
	chatBot = true,
	dockNavbar = true,
} = Astro.props
const t = dictionary[lang]
---

<html lang={lang} class='scroll-smooth'>
	<head>
		<script is:inline data-astro-rerun>
			;(() => {
				const theme = localStorage.getItem('theme')
				const prefersDark = window.matchMedia(
					'(prefers-color-scheme: dark)',
				).matches
				const prefersReducedMotion = window.matchMedia(
					'(prefers-reduced-motion: reduce)',
				).matches
				if (theme === 'dark' || (!theme && prefersDark)) {
					document.documentElement.classList.add('dark')
				} else {
					document.documentElement.classList.remove('dark')
				}
				document.documentElement.classList.toggle(
					'motion-safe',
					!prefersReducedMotion,
				)
				document.documentElement.classList.toggle(
					'motion-reduce',
					prefersReducedMotion,
				)
			})()
		</script>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width' />
		<Seo {...seo} lang={lang} />
		{articleSchema && <ArticleSchema {...articleSchema} />}
	</head>
	<body class='font-sans text-foreground bg-background'>
		<BackgroundParticles client:load />
		<Navbar
			lang={lang}
			pathname={Astro.url.pathname}
			languageSwitchUrls={languageSwitchUrls}
			t={t}
			dockNavbar={dockNavbar}
			client:load
		/>
		<main>
			<slot />
		</main>
		{chatBot && <ChatBot client:idle t={t} lang={lang} />}
		<Footer lang={lang} />
		<script>
			import { initRevealObserver } from '@/lib/motion'

			initRevealObserver()
		</script>
	</body>
</html>
