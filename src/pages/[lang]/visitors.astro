---
import VisitorsPage from '@/components/pages/visitors.astro'
import { LANGUAGES, type Language } from '@/i18n/i18n'

export const prerender = false

const langParam = Astro.params.lang
if (!langParam || !LANGUAGES.includes(langParam as Language)) {
	return Astro.rewrite('/404')
}

const lang = langParam as Language
---

<VisitorsPage lang={lang} />
